<script define:vars={{ carouselWords }}>
  // ---------- Word carousel (typewriter) ----------
  (function () {
    const el = document.getElementById('carousel-word');
    if (!el) return;
    const typeSpeed = 90;    // ms per typed letter
    const eraseSpeed = 45;   // ms per erased letter
    const holdFull = 1500;   // pause once fully typed
    const holdEmpty = 350;   // pause once erased
    let idx = 0;
    let pos = 0;
    let erasing = false;

    el.style.animation = 'none';
    el.textContent = '';

    function tick() {
      const word = carouselWords[idx];
      if (!erasing) {
        pos++;
        el.textContent = word.slice(0, pos);
        if (pos === word.length) {
          erasing = true;
          setTimeout(tick, holdFull);
        } else {
          setTimeout(tick, typeSpeed);
        }
      } else {
        pos--;
        el.textContent = word.slice(0, pos);
        if (pos === 0) {
          erasing = false;
          idx = (idx + 1) % carouselWords.length;
          setTimeout(tick, holdEmpty);
        } else {
          setTimeout(tick, eraseSpeed);
        }
      }
    }

    setTimeout(tick, holdFull);
  })();

  // ---------- Interactive node network ----------
  (function () {
    const canvas = document.getElementById('net-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const mouse = { x: -9999, y: -9999, active: false };
    let w = 0, h = 0;
    let nodes = [];

    const rand = (a, b) => a + Math.random() * (b - a);

    const seed = () => {
      const target = Math.max(26, Math.min(46, Math.round((w * h) / 9000)));
      nodes = [];
      for (let i = 0; i < target; i++) {
        const hub = Math.random() < 0.22;
        nodes.push({
          x: rand(w * 0.12, w * 0.88),
          y: rand(h * 0.12, h * 0.88),
          vx: rand(-0.25, 0.25),
          vy: rand(-0.25, 0.25),
          m: hub ? rand(1.8, 2.6) : rand(0.7, 1.2),
          hub,
          ph: Math.random() * Math.PI * 2,
        });
      }
    };

    // Re-measure only when the container's *integer* device-pixel size
    // actually changes. Writing canvas.width/height clears the bitmap and
    // resets the transform, so doing it on every subpixel jitter is what
    // made resizing look broken.
    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      const cssW = rect.width, cssH = rect.height;
      if (!cssW || !cssH) return;                 // not laid out yet
      const bw = Math.round(cssW * dpr);
      const bh = Math.round(cssH * dpr);
      if (canvas.width === bw && canvas.height === bh) return; // nothing changed
      // remap existing nodes from the old logical size into the new one
      if (w && h && nodes.length) {
        const sx = cssW / w, sy = cssH / h;
        for (const nd of nodes) { nd.x *= sx; nd.y *= sy; }
      }
      canvas.width = bw;
      canvas.height = bh;
      w = cssW; h = cssH;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);     // draw in CSS pixels
      if (nodes.length === 0) seed();
    };
    resize();
    // Observe the parent box (not the canvas itself) so resizing the
    // backing buffer can never feed back into the observer.
    const ro = new ResizeObserver(resize);
    ro.observe(canvas.parentElement || canvas);

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
      mouse.active = true;
    });
    canvas.addEventListener('mouseleave', () => { mouse.active = false; mouse.x = -9999; mouse.y = -9999; });

    // --- Tunable physics constants ---
    const LINK = 160;       // px: two nodes link (draw a line + spring) when closer than this
    const REPEL = 3500;     // node-to-node push-apart strength; higher = more spread out
    const SPRING = 0.02;    // pull along links toward REST length; higher = tighter clusters
    const REST = 100;        // px: resting distance a link wants to settle at
    const CENTER = 0.0006;  // pull toward canvas center; higher = stays framed, lower = drifts to edges
    const WANDER = 5;       // ambient drift force; higher = nodes roam more freely at rest, 0 = settle still
    const MOUSE_R = 140;    // px: cursor influence radius
    const MOUSE_F = 5.0;    // cursor push strength
    const DAMP = 0.9;       // velocity retained each step (0–1); higher = more glide/momentum, lower = stops fast
    const MAX_SPEED = 3;  // px/step velocity clamp; caps how fast a node can fly
    const DT = 1 / 60;      // fixed physics timestep (seconds) — keeps motion identical on 60/120/144Hz screens
    let t = 0;

    const step = () => {
      t += DT;
      const n = nodes.length;
      for (let i = 0; i < n; i++) {
        const a = nodes[i];
        let fx = 0, fy = 0;
        fx += (w / 2 - a.x) * CENTER;
        fy += (h / 2 - a.y) * CENTER;
        // gentle deterministic wander so the cloud keeps breathing at rest
        fx += Math.cos(t * 0.5 + a.ph) * WANDER;
        fy += Math.sin(t * 0.4 + a.ph * 1.3) * WANDER;
        for (let j = 0; j < n; j++) {
          if (i === j) continue;
          const b = nodes[j];
          let dx = a.x - b.x, dy = a.y - b.y;
          let d2 = dx * dx + dy * dy;
          if (d2 < 0.01) { dx = rand(-1, 1); dy = rand(-1, 1); d2 = 1; }
          const d = Math.sqrt(d2);
          const rep = (REPEL * b.m) / d2;
          fx += (dx / d) * rep;
          fy += (dy / d) * rep;
          if (d < LINK) {
            const s = (d - REST) * SPRING;
            fx -= (dx / d) * s;
            fy -= (dy / d) * s;
          }
        }
        if (mouse.active) {
          const dx = a.x - mouse.x, dy = a.y - mouse.y;
          const d = Math.hypot(dx, dy) || 0.001;
          if (d < MOUSE_R) {
            const f = 1 - d / MOUSE_R;
            const push = f * f * MOUSE_F * (1 / a.m + 0.4);
            fx += (dx / d) * push * 60;
            fy += (dy / d) * push * 60;
          }
        }
        a.vx = (a.vx + fx * DT) * DAMP;
        a.vy = (a.vy + fy * DT) * DAMP;
        const sp = Math.hypot(a.vx, a.vy);
        if (sp > MAX_SPEED) { a.vx = (a.vx / sp) * MAX_SPEED; a.vy = (a.vy / sp) * MAX_SPEED; }
      }
      const pad = 10;
      for (const a of nodes) {
        a.x += a.vx;
        a.y += a.vy;
        if (a.x < pad) { a.x = pad; a.vx *= -0.6; }
        if (a.x > w - pad) { a.x = w - pad; a.vx *= -0.6; }
        if (a.y < pad) { a.y = pad; a.vy *= -0.6; }
        if (a.y > h - pad) { a.y = h - pad; a.vy *= -0.6; }
      }
    };

    const draw = () => {
      ctx.clearRect(0, 0, w, h);
      const n = nodes.length;
      for (let i = 0; i < n; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < n; j++) {
          const b = nodes[j];
          const dx = a.x - b.x, dy = a.y - b.y;
          const d = Math.hypot(dx, dy);
          if (d < LINK) {
            const prox = 1 - d / LINK;
            let mInf = 0;
            if (mouse.active) {
              const mx = (a.x + b.x) / 2 - mouse.x;
              const my = (a.y + b.y) / 2 - mouse.y;
              mInf = Math.max(0, 1 - Math.hypot(mx, my) / 200);
            }
            const op = prox * (0.2 + mInf * 0.6);
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = 'rgba(59,110,240,' + op.toFixed(3) + ')';
            ctx.lineWidth = 0.5 + prox * 0.9 + mInf * 0.8;
            ctx.stroke();
          }
        }
      }
      for (const a of nodes) {
        let mInf = 0;
        if (mouse.active) {
          mInf = Math.max(0, 1 - Math.hypot(a.x - mouse.x, a.y - mouse.y) / MOUSE_R);
        }
        const pulse = 0.5 + 0.5 * Math.sin(t * 1.6 + a.ph);
        const rad = a.m * (1.7 + pulse * 0.5) + mInf * 2.4;
        if (a.hub || mInf > 0.05) {
          ctx.beginPath();
          ctx.arc(a.x, a.y, rad + 5 + mInf * 6, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(59,110,240,' + (0.05 + mInf * 0.14).toFixed(3) + ')';
          ctx.fill();
        }
        ctx.beginPath();
        ctx.arc(a.x, a.y, rad, 0, Math.PI * 2);
        const bright = a.hub ? 0.85 : 0.55;
        ctx.fillStyle = mInf > 0.05
          ? 'rgba(' + Math.round(120 + mInf * 135) + ',' + Math.round(150 + mInf * 90) + ',255,' + (bright + mInf * 0.15).toFixed(2) + ')'
          : 'rgba(59,110,240,' + bright + ')';
        ctx.fill();
      }
    };

    // rAF render loop synced to the display (smooth), with a fixed-timestep
    // accumulator so physics stays stable regardless of refresh rate.
    let last = performance.now();
    let acc = 0;
    const loop = (now) => {
      try {
        if (w && h && nodes.length) {
          let elapsed = (now - last) / 1000;
          if (elapsed > 0.1) elapsed = 0.1; // clamp big gaps (e.g. tab was hidden)
          acc += elapsed;
          let steps = 0;
          while (acc >= DT && steps < 5) { step(); acc -= DT; steps++; }
          draw();
        }
      } catch (e) { /* never let one bad frame kill the loop */ }
      last = now;
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
  })();
</script>

<style>
  .page {
    width: 100%;
  }

  /* ===================== HERO ===================== */
  .hero {
    min-height: 100vh;   /* fallback for browsers without dvh */
    min-height: 100dvh;  /* fills the *visible* viewport on mobile (accounts for address bar) */
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 200px;
    max-width: 1480px;
    margin: 0 auto;
    padding: 48px 56px;
    box-sizing: border-box;
  }
  .hero-text {
    flex: 1 1 460px;
    min-width: 300px;
    max-width: 720px;
    display: flex;
    flex-direction: column;
  }
  .kicker {
    margin: 0 0 14px;
    font-size: 15px;
    letter-spacing: 0.01em;
    color: #9a9aa3;
    font-weight: 500;
  }
  .name {
    margin: 0;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 0.96;
    font-size: clamp(52px, 9vw, 104px);
    color: #f4f4f6;
  }
  .tagline {
    margin: 18px 0 0;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: clamp(22px, 3.4vw, 34px);
    color: #c4c4cc;
    display: flex;
    align-items: baseline;
    gap: 0.32em;
    flex-wrap: wrap;
  }
  .carousel {
    display: inline-flex;
    align-items: baseline;
  }
  .carousel-word {
    display: inline-block;
    color: #3b6ef0;
    font-weight: 600;
  }
  .caret {
    display: inline-block;
    width: 3px;
    height: 0.95em;
    margin-left: 4px;
    background: #3b6ef0;
    transform: translateY(0.08em);
    animation: caretBlink 1s steps(1) infinite;
  }

  /* Section nav — list variant */
  .sec-nav {
    margin-top: clamp(36px, 6vh, 64px);
    display: flex;
    flex-direction: column;
    border-top: 1px solid #222229;
  }
  .sec-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 16px 4px;
    border-bottom: 1px solid #222229;
    transition: padding-left 0.2s ease;
  }
  .sec-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    color: #3b6ef0;
    font-weight: 600;
    width: 28px;
  }
  .sec-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 19px;
    font-weight: 600;
    color: #f4f4f6;
    width: 160px;
    transition: color 0.2s ease;
  }
  .sec-desc {
    font-size: 14px;
    color: #8a8a93;
    flex: 1;
  }
  .sec-arrow {
    font-size: 18px;
    color: #5a5a63;
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .sec-link:hover {
    padding-left: 14px;
  }
  .sec-link:hover .sec-title,
  .sec-link:hover .sec-arrow {
    color: #3b6ef0;
  }
  .sec-link:hover .sec-arrow {
    transform: translateX(4px);
  }

  /* Social links */
  .socials {
    margin-top: 32px;
    display: flex;
